# Caddyfile for Railway deployment
{
    # Disables the admin interface to prevent port conflicts on Railway
    admin off
    # Integrates FrankenPHP directly into Caddy
    frankenphp
}

:{$PORT} {
    # Points exactly to where Railway places your files
    root * /app

    # Standard FrankenPHP routing for public PHP files
    route {
        php_server
    }
}
